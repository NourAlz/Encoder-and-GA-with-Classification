

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import math
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import LabelEncoder
from tensorflow.keras import layers, models
from tensorflow.keras.utils import to_categorical

# Step 1: Load actual signal data
X_df = pd.read_excel('minmax_normalized_dataset.xlsx')  # shape: (444, 900)
y_df = pd.read_csv('idC_with_header.csv')               # shape: (443,)

# Step 2: Drop last unmatched row
X_df = X_df.iloc[:443, :]  # match to label count

# Step 3: Extract features and labels
X = X_df.to_numpy().astype('float32')                   # shape: (443, 900)
y = y_df.iloc[:, 0].to_numpy()                          # extract label column (adjust if needed)

# Step 4: Encode string labels to integers
label_encoder = LabelEncoder()
y_encoded = label_encoder.fit_transform(y)
num_classes = len(np.unique(y_encoded))

# Step 5: Reshape signals into 30x30 grayscale images
X_img = X.reshape(-1, 30, 30, 1)

# Step 6: One-hot encode labels
y_cat = to_categorical(y_encoded, num_classes)

# Step 7: Train-test split
X_train, X_test, y_train, y_test = train_test_split(X_img, y_cat, test_size=0.2, random_state=42)

# Step 8: Build CNN
model = models.Sequential([
    layers.Input(shape=(30, 30, 1)),
    layers.Conv2D(32, 3, activation='relu'),
    layers.MaxPooling2D(2),
    layers.Conv2D(64, 3, activation='relu'),
    layers.MaxPooling2D(2),
    layers.Flatten(),
    layers.Dense(64, activation='relu'),
    layers.Dense(num_classes, activation='softmax')
])

model.compile(optimizer='adam', loss='categorical_crossentropy', metrics=['accuracy'])

# Step 9: Train CNN
model.fit(X_train, y_train, epochs=10, batch_size=32, validation_data=(X_test, y_test))

# Step 10: Visualize ALL images with real labels in batches
batch_size = 10
num_images = X_img.shape[0]
total_batches = math.ceil(num_images / batch_size)

for batch in range(total_batches):
    start = batch * batch_size
    end = min(start + batch_size, num_images)
    images = X_img[start:end].reshape(-1, 30, 30)
    labels = label_encoder.inverse_transform(y_encoded[start:end])  # real class names

    fig, axes = plt.subplots(1, len(images), figsize=(2 * len(images), 2))
    for i, ax in enumerate(axes):
        ax.imshow(images[i], cmap='magma')
        ax.set_title(f"Label: {labels[i]}", fontsize=8)
        ax.axis('off')
    plt.tight_layout()
    plt.show()

test_loss, test_acc = model.evaluate(X_test, y_test, verbose=0)
print(f"\n✅ Test Accuracy: {test_acc * 100:.2f}%")

from sklearn.metrics import classification_report, confusion_matrix, ConfusionMatrixDisplay
import numpy as np
import matplotlib.pyplot as plt

# Predict class indices
y_pred_probs = model.predict(X_test)
y_pred_classes = np.argmax(y_pred_probs, axis=1)
y_true_classes = np.argmax(y_test, axis=1)

# Get class labels and indices
class_names = label_encoder.classes_
# Convert class names to strings if they are not already strings
class_names = [str(class_name) for class_name in class_names]
all_labels = np.arange(len(class_names))  # [0, 1, ..., 13]

# Corrected classification report
print("\n🔍 Classification Report:")
print(classification_report(y_true_classes, y_pred_classes, labels=all_labels, target_names=class_names, zero_division=0))

# Confusion matrix
cm = confusion_matrix(y_true_classes, y_pred_classes, labels=all_labels)
disp = ConfusionMatrixDisplay(confusion_matrix=cm, display_labels=class_names)
disp.plot(xticks_rotation=90, cmap='viridis')
plt.title("📊 Confusion Matrix")
plt.tight_layout()
plt.show()

